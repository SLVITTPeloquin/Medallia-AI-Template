# Service
PORT=3000
NODE_ENV=development

# Environment gating: sandbox | production
APP_ENV=sandbox
ENFORCE_SANDBOX_ONLY=true

# Safety controls
ALLOW_PROD_AUTOSEND=false

# Optional LLM config (if unset, service uses deterministic local draft generation)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Zingle API (for reporting scripts)
ZINGLE_BASE_URL=https://api.zingle.me/v1
ZINGLE_SERVICE_ID=28c85936-6458-4d8a-8e7f-2e3b54bec37d

# Option A: JWT bearer auth
ZINGLE_TOKEN=

# Option B: Basic auth (username/password)
ZINGLE_USERNAME=
ZINGLE_PASSWORD=

# Sandbox email inbox (Microsoft Graph)
EMAIL_PROVIDER=microsoft-graph
EMAIL_MAILBOX=me
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_AUTHORITY_URL=https://login.microsoftonline.com
MS_GRAPH_SCOPES=offline_access User.Read Mail.Read
MS_GRAPH_LOGIN_HINT=
MS_GRAPH_TOKEN_CACHE_PATH=.graph-token-cache.json
